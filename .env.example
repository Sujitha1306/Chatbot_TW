# TrackerWave — copy to .env and fill in real values
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

CLICKHOUSE_HOST=your-host-ip
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=your-password-here
CLICKHOUSE_DATABASE=ovitag_dw

JWT_SECRET=generate-32-byte-hex-here
JWT_EXPIRE_HOURS=24

API_KEY=generate-urlsafe-token-here
ADMIN_TOKEN=generate-urlsafe-token-here
ALLOWED_ORIGINS=http://localhost:3000

ENVIRONMENT=development
APP_PORT=8000

# Demo user (Phase 3 bridge — replaced by DB in Phase 6)
