# TrackerWave Analytics Platform v3.1 Configuration Template
# Copy this file to .env and update with your actual credentials

# Azure OpenAI Configuration - GPT-4.1 (Enhanced Performance)
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ClickHouse Database Configuration (Pre-configured for TrackerWave)
CLICKHOUSE_HOST=your-host-ip
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=your-password-here
CLICKHOUSE_DATABASE=ovitag_dw

# Enhanced Application Configuration
LOG_LEVEL=INFO
MAX_QUERY_TIMEOUT=30
DEFAULT_ROW_LIMIT=100
DEFAULT_TIMEZONE=Asia/Kolkata

# Enhanced Feature Flags
ENABLE_PREDICTIONS=true
ENABLE_MULTI_TURN=true
ENABLE_TIMEZONE_SUPPORT=true

# Flask API Configuration
FLASK_DEBUG=False
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Performance Settings for GPT-4.1
AI_MODEL=gpt-4.1
AI_TEMPERATURE=0.1
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

ADMIN_TOKEN=change-this-to-a-random-string

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-generated-api-key-here
